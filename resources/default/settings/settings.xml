<settings>
    <setting propertyKey="@Properties.weekStartDay" title="@Strings.WeekStartDayTitle">
        <settingConfig type="list">
            <listEntry value="0">@Strings.WeekStartSaturday</listEntry>
            <listEntry value="1">@Strings.WeekStartSunday</listEntry>
            <listEntry value="2">@Strings.WeekStartMonday</listEntry>
        </settingConfig>
    </setting>
    <setting propertyKey="@Properties.showGregorianInGlance" title="@Strings.ShowGregorianInGlanceTitle">
        <settingConfig type="list">
            <listEntry value="1">@Strings.SettingOn</listEntry>
            <listEntry value="0">@Strings.SettingOff</listEntry>
        </settingConfig>
    </setting>
    <setting propertyKey="@Properties.persianYearMode" title="@Strings.PersianYearModeTitle">
        <settingConfig type="list">
            <listEntry value="0">@Strings.PersianYearModeHijri</listEntry>
            <listEntry value="1">@Strings.PersianYearModeShahanshahi</listEntry>
        </settingConfig>
    </setting>
    <setting propertyKey="@Properties.dateSeparator" title="@Strings.DateSeparatorTitle">
        <settingConfig type="list">
            <listEntry value="0">@Strings.DateSeparatorSlash</listEntry>
            <listEntry value="1">@Strings.DateSeparatorDash</listEntry>
            <listEntry value="2">@Strings.DateSeparatorDot</listEntry>
            <listEntry value="3">@Strings.DateSeparatorSpace</listEntry>
        </settingConfig>
    </setting>
</settings>
